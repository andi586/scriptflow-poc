                      plan.highlight
                        ? "bg-[#D4A017] text-black hover:bg-[#e8b520]"
                        : "border border-[#D4A017]/50 text-[#D4A017] hover:bg-[#D4A017]/10"
                    }`}
                  >
                    Get Your Pass
                  </Link>
                </div>
              </FadeUp>
            ))}
          </div>
        </div>
      </section>

      {/* ══════════════════════════════════════════════════════════════════════
          MODULE 8 · THE FIRST 5 DIRECTORS
      ══════════════════════════════════════════════════════════════════════ */}
      <section className="py-28 border-t border-white/5">
        <div className="mx-auto max-w-3xl px-6 text-center">
          <FadeUp>
            {/* 5 golden seat icons */}
            <div className="mb-8 flex justify-center gap-3">
              {[...Array(5)].map((_, i) => (
                <div
                  key={i}
                  className="h-10 w-10 rounded-full border-2 border-[#D4A017] bg-[#D4A017]/10 flex items-center justify-center text-[#D4A017] text-lg"
                >
                  ★
                </div>
              ))}
            </div>
          </FadeUp>
          <FadeUp delay={100}>
            <h2
              className="mb-4 text-3xl font-extrabold sm:text-5xl leading-tight"
              style={{ fontFamily: "'Montserrat', sans-serif" }}
            >
              Only 5 golden seats left
              <br />
              <span className="text-[#D4A017]">in the front row.</span>
            </h2>
          </FadeUp>
          <FadeUp delay={200}>
            <p className="mb-10 text-white/50 text-lg">
              The first 5 directors get lifetime access, founding credits, and
              their name in the Heaven Cinema opening reel.
            </p>
          </FadeUp>
          <FadeUp delay={300}>
            <Link
              href="/app-flow"
              className="inline-block rounded-xl bg-[#D4A017] px-12 py-5 text-lg font-bold text-black transition-all hover:bg-[#e8b520] hover:shadow-2xl hover:shadow-[#D4A017]/40 active:scale-95"
            >
              Reserve My Golden Seat
            </Link>
          </FadeUp>
          <FadeUp delay={400}>
            <p className="mt-8 text-xs text-white/25">
              getscriptflow.com · @wolfemperorai
            </p>
          </FadeUp>
        </div>
      </section>

      {/* ── Video Modal ── */}
      <VideoModal open={showModal} onClose={() => setShowModal(false)} />

      {/* ══════════════════════════════════════════════════════════════════════
          FOOTER
      ══════════════════════════════════════════════════════════════════════ */}
      <footer className="border-t border-white/5 py-10">
        <div className="mx-auto max-w-6xl px-6 text-center space-y-3">
          <p
            className="text-sm font-bold text-[#D4A017]"
            style={{ fontFamily: "'Montserrat', sans-serif" }}
          >
            Heaven Cinema
          </p>
          <p className="text-xs text-white/30">
            © 2026 ScriptFlow LLC · Wyoming USA
          </p>
          <p className="text-xs text-white/25">
            <Link
              href="/privacy"
              className="hover:text-white/50 transition-colors"
            >
              Privacy Policy
            </Link>
            {" · "}
            <Link
              href="/terms"
              className="hover:text-white/50 transition-colors"
            >
              Terms of Service
            </Link>
            {" · "}
            <span>heavencinema.ai</span>
          </p>
          <p className="text-xs text-white/20 italic">Your IP, your rules.</p>
        </div>
      </footer>
    </div>
  );
}
