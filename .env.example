# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres URI for CLI/scripts only (Settings → Database). Needed for: npm run db:migrate:kling-project-id
DATABASE_URL=

# Claude (NEL Sentinel + translator)
ANTHROPIC_API_KEY=

# PiAPI Kling
KLING_API_KEY=
KLING_API_BASE=https://api.piapi.ai/api/v1
# Reference images: PiAPI Kling Elements uses input.elements [{ image_url }], not "reference_images".
# See lib/kling-piapi-payload.ts and https://piapi.ai/docs/kling-api/kling-elements

# Optional: real Supabase Auth user UUID for “New project (demo)” on the home page
SCRIPTFLOW_DEMO_USER_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
