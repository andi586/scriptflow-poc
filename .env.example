# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres URI for scripts (Settings → Database → Connection string → URI). Required for: npm run db:migrate
DATABASE_URL=

# Claude (NEL Sentinel + translator)
ANTHROPIC_API_KEY=

# PiAPI Kling
KLING_API_KEY=
KLING_API_BASE=https://api.piapi.ai/api/v1
# Reference images: PiAPI Kling Elements uses input.elements [{ image_url }], not "reference_images".
# See lib/kling-piapi-payload.ts and https://piapi.ai/docs/kling-api/kling-elements

# Supabase Auth user UUID (must exist in auth.users). Used when clicking “New Project” on the home page.
# Either variable works; set at least one in Vercel + .env.local.
SCRIPTFLOW_DEMO_USER_ID=
SCRIPTFLOW_PROJECT_OWNER_USER_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
